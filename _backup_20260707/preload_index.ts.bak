    ipcRenderer.invoke('ext:media:status'),
  onChatChunk: (fn: (s: string) => void) => {
    ipcRenderer.removeAllListeners('chat:chunk')
    ipcRenderer.on('chat:chunk', (_e, s: string) => fn(s))
